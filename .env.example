# ─── Neo4j Community Edition ──────────────────────────────────────────────────
# Format: username/password — must match on both sides
NEO4J_AUTH=neo4j/repomind_secret
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=repomind_secret

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=chroma
CHROMA_PORT=8000

# ─── Ollama (local, free, no API key) ─────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=qwen2.5-coder:7b

# ─── GitHub OAuth App ─────────────────────────────────────────────────────────
# 1. Go to https://github.com/settings/applications/new
# 2. Application name: RepoMind (or anything)
# 3. Homepage URL: http://localhost:3000
# 4. Authorization callback URL: http://localhost:3000/api/auth/callback/github
# 5. Click "Register application" → copy the Client ID and generate a secret
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# ─── Optional: Groq (faster LLM inference, free tier, no card needed) ─────────
# Sign up at https://console.groq.com — free tier gives generous rate limits
# Leave empty to use local Ollama exclusively
GROQ_API_KEY=

# ─── Frontend (browser-visible) ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# Optional public mock-data demo. Do not enable with a real backend.
NEXT_PUBLIC_DEMO_MODE=false

# Comma-separated origins permitted to call the FastAPI service
# Example: https://repomind.vercel.app
CORS_ORIGINS=http://localhost:3000
